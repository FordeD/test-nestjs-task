{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^libs/(.*)$": "<rootDir>/src/libs/$1",
    "^apps/(.*)$": "<rootDir>/src/apps/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.(t|j)s"
  ],
  "coverageDirectory": "./coverage",
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/"
  ]
}
